#include <iostream>
#include string

using namespace std;




void masukanData(float &berat, float &tinggi){
    cout  << "Masukan Berat Badan (kg): ";
    cin >> berat;
    cout << "Masukan tinggi badan (meter): ";
    cin >> tinggi;
}

float hitungBMI(float berat, float tinggi){
    return berat / (tinggi * tinggi);
}

string tentukanKondisi(float bmi){
    if (bmi < 18.5){
        return "Berat Badan Kurang";
    } else if (bmi < 25){
        return "Berat Badan Normal";
    } else if (bmi < 30){
        return "Berat Badan Kelebihan"
    } else{
        return "Obesitas";
    }

}

int main(){
    float berat, tinggi, nilaiBMI;


    cout << --- Selamat Datang Mahasiswa kelas A 2025 ---" endl;


    masukanData (berat, tinggi);


    nilaiBMI = hitungBMI(berat, tinggi);

     
    cout << endl << "--- Hasil ---" << endl;
    cout << "BMI Anda : " << nilaiBMI << endl;


    
}
